         Filter: ((properties @> '{"id": 1}'::agtype) AND agtype_object_field_equals(properties, '"id"'::agtype, '1'::agtype))
   ->  Seq Scan on "S" s2
         Filter: ((properties @> '{"id": 2}'::agtype) AND agtype_object_field_equals(properties, '"id"'::agtype, '2'::agtype))
   ->  Seq Scan on "S" s3
