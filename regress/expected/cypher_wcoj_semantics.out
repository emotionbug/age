          (s2:S {id: 2})-[e2:E]->(t),
          (s3:S {id: 3})-[e3:E]->(t)
    RETURN DISTINCT id(t) AS key
$$) AS (key agtype);
SELECT (SELECT count(*) FROM wcoj_distinct_key_binary) AS binary_rows,
