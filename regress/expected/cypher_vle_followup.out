/*
 * VLE follow-up coverage for boundary and dense-state behavior.
 */
LOAD 'age';
SET search_path TO ag_catalog;
\pset format unaligned
SELECT create_graph('cypher_vle_followup');
NOTICE:  graph "cypher_vle_followup" has been created
create_graph

(1 row)
SELECT * FROM cypher('cypher_vle_followup', $$
    CREATE
        (a:Node {name: 'a'}),
        (b:Node {name: 'b'}),
        (c:Node {name: 'c'}),
        (d:Node {name: 'd'}),
        (a)-[:E {kind: 'chain'}]->(b),
        (b)-[:E {kind: 'chain'}]->(c),
        (c)-[:E {kind: 'chain'}]->(d),
        (c)-[:E {kind: 'back'}]->(b),
        (b)-[:E {kind: 'self'}]->(b),
        (a)-[:D {bucket: 0}]->(c),
        (a)-[:D {bucket: 1}]->(d),
        (b)-[:D {bucket: 0}]->(d),
        (c)-[:D {bucket: 1}]->(a)
$$) AS (r agtype);
r
(0 rows)
CREATE TEMP TABLE vle_followup_points AS
SELECT * FROM cypher('cypher_vle_followup', $$
    MATCH (a:Node {name: 'a'}), (d:Node {name: 'd'})
    RETURN a, d
$$) AS (a agtype, d agtype);
-- Reversed two-bound traversal should find the reverse chain and back edge.
SELECT * FROM cypher('cypher_vle_followup', $$
    MATCH p=(:Node {name: 'd'})<-[*2..3]-(:Node {name: 'a'})
    RETURN count(p)
$$) AS (paths agtype);
paths
6
(1 row)
-- Zero-length two-bound traversal emits only when both endpoints are identical.
SELECT * FROM cypher('cypher_vle_followup', $$
    MATCH p=(:Node {name: 'a'})-[*0..0]->(:Node {name: 'a'})
    RETURN count(p)
$$) AS (paths agtype);
paths
1
(1 row)
SELECT * FROM cypher('cypher_vle_followup', $$
    MATCH p=(:Node {name: 'a'})-[*0..0]->(:Node {name: 'b'})
    RETURN count(p)
$$) AS (paths agtype);
paths
0
(1 row)
-- Empty finite ranges should not traverse.
SELECT count(edges) FROM vle_followup_points,
age_vle(
    '"cypher_vle_followup"'::agtype,
    a,
    d,
    '{"id": 1111111111111111, "label": "", "end_id": 2222222222222222, "start_id": 333333333333333, "properties": {}}::edge'::agtype,
    '3'::agtype,
    '2'::agtype,
    '1'::agtype);
count
0
(1 row)
-- Unbound-start VLE with a missing endpoint should return no rows.
SELECT * FROM cypher('cypher_vle_followup', $$
    MATCH p=()-[*1..2]->(:Missing {name: 'nope'})
    RETURN count(p)
$$) AS (paths agtype);
paths
0
(1 row)
-- Dense edge-index traversal state should preserve branch uniqueness.
SELECT * FROM cypher('cypher_vle_followup', $$
    MATCH p=(:Node {name: 'a'})-[:D*1..2]->()
    RETURN count(p)
$$) AS (paths agtype);
paths
3
(1 row)
DROP TABLE vle_followup_points;
SELECT drop_graph('cypher_vle_followup', true);
NOTICE:  drop cascades to 5 other objects
DETAIL:  drop cascades to table cypher_vle_followup._ag_label_vertex
drop cascades to table cypher_vle_followup._ag_label_edge
drop cascades to table cypher_vle_followup."Node"
drop cascades to table cypher_vle_followup."E"
drop cascades to table cypher_vle_followup."D"
NOTICE:  graph "cypher_vle_followup" has been dropped
drop_graph

(1 row)
\pset format aligned
