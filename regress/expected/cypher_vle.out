               ->  Seq Scan on middle _age_default_vle_function_start_var_39_3
               ->  Seq Scan on "end" _age_default_vle_function_start_var_39_4
         ->  Nested Loop
               ->  Seq Scan on "end" _age_default_vle_function_end_var_40
               ->  Custom Scan (AGE VLE Stream)
(10 rows)

