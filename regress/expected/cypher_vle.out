       format('{"i": %s}', CASE WHEN g = 62 THEN 59 ELSE g END)::agtype
FROM (
    SELECT 1 AS g
    UNION ALL SELECT 62
    UNION ALL SELECT 199
    UNION ALL SELECT generate_series(220, 252)
) s;
