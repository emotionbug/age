ANALYZE generic_ghd."B";
ANALYZE generic_ghd."C";
ANALYZE generic_ghd."D";
ANALYZE generic_ghd."X";
ANALYZE generic_ghd."GPA";
ANALYZE generic_ghd."GPB";
ANALYZE generic_ghd."GPC";
ANALYZE generic_ghd."GPD";
