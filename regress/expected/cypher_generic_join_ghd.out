              -[e3:E3]->(d:D)-[e4:E4]->(a),
              (c)-[t:TX]->(x:X)
        RETURN id(a) AS a
    $$) AS (a agtype)
) AS exists_match;
SELECT (SELECT exists_match FROM generic_ghd_binary_exists) AS binary_exists,
       (SELECT exists_match FROM generic_ghd_join_exists) AS generic_exists,
       (SELECT count(*) FROM (
