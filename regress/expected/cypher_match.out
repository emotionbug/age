CREATE FUNCTION pg_temp.normalized_verbose_explain(query text)
RETURNS TABLE(plan text)
LANGUAGE plpgsql
AS $$
DECLARE
    plan_text text;
BEGIN
    FOR plan_text IN EXECUTE 'EXPLAIN (VERBOSE, COSTS OFF) ' || query
    LOOP
        plan := regexp_replace(plan_text, '''[0-9]+''::oid',
                               '''<graph_oid>''::oid', 'g');
        RETURN NEXT;
    END LOOP;
END;
$$;
SELECT * FROM pg_temp.normalized_verbose_explain($plan$
SELECT *
FROM cypher('cypher_match',
            $$MATCH p=(:v1)-[:e1]->(:v1)-[:e1]->(:v1)
              RETURN count(p)$$) AS (c agtype)
$plan$);
                                                                                                                   plan                                                                                                                    
-------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
 Aggregate
   Output: (count(_age_default_alias_0.id))::agtype
   ->  Nested Loop
         Output: _age_default_alias_0.id
         ->  Seq Scan on cypher_match.v1 _age_default_alias_0
               Output: _age_default_alias_0.id, _age_default_alias_0.properties
         ->  Custom Scan (AGE VLE Stream)
               VLE Shape: cypher
               VLE Arguments: 9
               VLE Argument Slots: graph=const, start=dynamic, end=const, edge=const, lower=const, upper=const, direction=const, grammar-node=const, terminal-property=const
               VLE Graph: cypher_match
               VLE Edge: label=e1, properties=0
               VLE Edge Source: local-index-candidate, fixed-source=out=endpoint-btree/in=none, candidates=age_adjacency=-/- endpoint-btree=start/end, state=dense-local
               VLE Source Cost: reltuples=0 fanout=start:0/end:0 stats=rel:unknown/start:unknown/end:unknown source=start:statistics/end:statistics value-posting=start:none/end:none
               VLE Join Order: component=vle connector=vle-expand bound=out property=query-order rows=1 fanout=start:0/end:0 consumer=path class=path-materialized source=endpoint-direct candidates=1 next=none/none/none
               VLE Source Profile: consumer=path class=path-materialized active=out budget=1 weight=3 cache-seed=ineligible endpoint-headroom=0.75 empty-lifecycle=ineligible/depth:0 empty-batch=ineligible/size:0
               VLE Source Threshold Input: source=none headroom=0 batch=0 direction=none reason=none class=none observed=0 saturated=0 relaxed=0
               VLE Source Payload Input: source=none headroom=0 scan-runs=0 replay-runs=0 seed-runs=0 replay-percent=0 seed-percent=0 observed=0 value-posting=none/observed:0 reason=none class=none
               VLE Source Policy: out=endpoint-btree/in=none depth=costed endpoint-work=sum(out:0/2,in:0/2) combined-work=all:0/0 reason=out:unknown-fanout/in:inactive-direction class=endpoint-direct recommendation=keep-endpoint-btree
               VLE Endpoints: start=runtime-id, end=const-id
               VLE Range: 2..2
               VLE Direction: right
               VLE Output: path(requirement=path, grammar=cached, terminal-label=4/all-depth)
               VLE Materialization: path-container, vertex-prefetch=label-batch(min-rel-candidates=8), object-source=label-row-fallback
               ->  Values Scan on _age_default_alias_1
(25 rows)

