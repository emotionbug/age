SELECT * FROM cypher_match_normalized_explain(
    'cypher_match_plan',
    'MATCH (:join_v)-[r:order_e]->(:join_v)
     RETURN r.i ORDER BY r.i::pg_bigint LIMIT 1');
                                                         cypher_match_normalized_explain                                                          
--------------------------------------------------------------------------------------------------------------------------------------------------
 Subquery Scan on _
   Output: _.i
   ->  Result
         Output: agtype_id_property_field_agtype('<relid>'::oid, r.id, 4, '"i"'::agtype), (agtype_object_field_int8(r.properties, '"i"'::agtype))
         ->  Limit
               Output: r.id, (agtype_object_field_int8(r.properties, '"i"'::agtype))
               ->  Sort
                     Output: r.id, (agtype_object_field_int8(r.properties, '"i"'::agtype))
                     Sort Key: (agtype_object_field_int8(r.properties, '"i"'::agtype))
                     ->  Hash Join
                           Output: r.id, (agtype_object_field_int8(r.properties, '"i"'::agtype))
                           Inner Unique: true
                           Hash Cond: (r.end_id = _age_default_alias_1.id)
                           ->  Hash Join
                                 Output: r.id, agtype_object_field_int8(r.properties, '"i"'::agtype), r.end_id
                                 Inner Unique: true
                                 Hash Cond: (r.start_id = _age_default_alias_0.id)
                                 ->  Seq Scan on cypher_match_plan.order_e r
                                       Output: r.id, r.start_id, r.end_id, r.properties
                                 ->  Hash
                                       Output: _age_default_alias_0.id
                                       ->  Seq Scan on cypher_match_plan.join_v _age_default_alias_0
                                             Output: _age_default_alias_0.id
                           ->  Hash
                                 Output: _age_default_alias_1.id
                                 ->  Seq Scan on cypher_match_plan.join_v _age_default_alias_1
                                       Output: _age_default_alias_1.id
(27 rows)

