-- Should return 2 rows on the very first execution
SELECT * FROM cypher('issue_2193', $$
    CREATE (a:Person {name: 'Jane', livesIn: 'London'}),
           (b:Person {name: 'Tom', livesIn: 'Copenhagen'})
