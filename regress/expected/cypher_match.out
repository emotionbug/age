               Group Key: CASE WHEN (r.id IS NOT NULL) THEN agtype_object_field_agtype(agtype_object_field_agtype(r.properties, '"payload"'::agtype), '"a"'::agtype) ELSE NULL::agtype END
               ->  Hash Join
                     Output: CASE WHEN (r.id IS NOT NULL) THEN agtype_object_field_agtype(agtype_object_field_agtype(r.properties, '"payload"'::agtype), '"a"'::agtype) ELSE NULL::agtype END
                     Inner Unique: true
                     Hash Cond: (r.end_id = b.id)
                     ->  Hash Join
                           Output: r.id, r.properties, r.end_id
                           Inner Unique: true
                           Hash Cond: (r.start_id = a.id)
                           ->  Seq Scan on cypher_match.e1 r
