 Result
   Output: (CASE WHEN (r.id IS NOT NULL) THEN agtype_object_field_agtype(agtype_object_field_agtype(r.properties, '"payload"'::agtype), '"a"'::agtype) ELSE NULL::agtype END), ((count(*)))::agtype
   ->  Sort
         Output: (CASE WHEN (r.id IS NOT NULL) THEN agtype_object_field_agtype(agtype_object_field_agtype(r.properties, '"payload"'::agtype), '"a"'::agtype) ELSE NULL::agtype END), (count(*))
